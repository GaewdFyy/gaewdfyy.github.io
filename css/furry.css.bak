/* 自定义 CSS for Fluid 主题 */

/* 定义通用变量，适配 Fluid 主题 */
:root {
  --card-background-light: rgba(255, 255, 255, 0.7); /* 白天模式卡片背景 */
  --card-background-dark: rgba(30, 39, 50, 0.6); /* 夜间模式卡片背景，深灰蓝 */
  --text-color-light: #2c3e50; /* 白天模式文字颜色 */
  --text-color-dark: #ecf0f1; /* 夜间模式文字颜色 */
  --container-background-light: linear-gradient(135deg, #f5e0a6, #fff5d1, #f0f8ff); /* 白天模式容器背景 */
  --container-background-dark: linear-gradient(135deg, #1a252f, #2c3e50, #26323d); /* 夜间模式容器背景，深灰蓝 */
  --border-color-light: rgba(255, 255, 255, 0.3); /* 白天模式边框 */
  --border-color-dark: rgba(255, 255, 255, 0.2); /* 夜间模式边框 */
}

/* 容器样式 */
.furry-container {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  margin: 40px auto;
  padding: 16px; /* 左右边距 16px */
  border-radius: 24px;
  max-width: 1200px;
  background: var(--container-background-light);
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1), 0 2px 4px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

/* 悬停效果 */
.furry-container:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15), 0 4px 8px rgba(0, 0, 0, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.6);
}

/* 文字区域样式 */
.furry-text {
  flex: 1;
  min-width: 250px;
  color: var(--text-color-light);
  background: var(--card-background-light);
  backdrop-filter: blur(6px);
  border-radius: 12px 0 0 12px; /* 左圆角，右无圆角 */
  padding: 16px;
  border: 1px solid var(--border-color-light);
  border-right: none; /* 无右边框，与图片无缝连接 */
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  line-height: 1.6;
  font-size: 16px;
}

/* 图片区域样式 */
.furry-img {
  flex: 0 0 auto;
  max-width: 300px; /* 限制最大宽度 */
  min-height: 200px;
}

.furry-img img {
  width: 100%;
  max-width: 100%;
  height: auto;
  border-radius: 0 12px 12px 0; /* 右圆角，左无圆角 */
  background: var(--card-background-light); /* 与文字区域背景一致 */
  backdrop-filter: blur(6px);
  border: 1px solid var(--border-color-light);
  border-left: none; /* 无左边框，与文字无缝连接 */
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.1), 0 2px 4px rgba(0, 0, 0, 0.06);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.furry-img img:hover {
  transform: scale(1.02);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15), 0 4px 8px rgba(0, 0, 0, 0.1);
}

/* 响应式设计 */
@media (max-width: 768px) {
  .furry-container {
    flex-direction: column;
    margin: 20px 10px;
    padding: 12px;
    gap: 15px; /* 移动端保留文字与图片间距 */
  }
  
  .furry-img {
    flex: 1 1 100%;
    max-width: 100%;
    min-height: 180px;
  }
  
  .furry-text {
    min-width: 100%;
    padding: 12px;
    font-size: 14px;
    border-radius: 12px; /* 移动端恢复完整圆角 */
    border: 1px solid var(--border-color-light); /* 恢复完整边框 */
  }
  
  .furry-img img {
    border-radius: 12px;
    border: 1px solid var(--border-color-light);
  }
}

@media (max-width: 480px) {
  .furry-container {
    margin: 10px 5px;
    padding: 10px;
    border-radius: 16px;
  }
  
  .furry-text {
    padding: 10px;
    border-radius: 8px;
    border: 1px solid var(--border-color-light);
  }
  
  .furry-img img {
    border-radius: 12px;
    border: 1px solid var(--border-color-light);
  }
}

/* Fluid 主题夜间模式适配 */
body.dark .furry-container {
  background: var(--container-background-dark);
  border-color: var(--border-color-dark);
}

body.dark .furry-text {
  background: var(--card-background-dark);
  color: var(--text-color-dark);
  border-color: var(--border-color-dark);
  border-right: none; /* 桌面端无缝连接 */
}

body.dark .furry-text h1,
body.dark .furry-text h2,
body.dark .furry-text h3 {
  color: #ffffff;
}

body.dark .furry-text p {
  color: #bdc3c7;
}

body.dark .furry-img img {
  background: var(--card-background-dark); /* 与夜间模式文字区域一致 */
  backdrop-filter: blur(6px);
  border-color: var(--border-color-dark);
  border-left: none; /* 桌面端无缝连接 */
}

@media (max-width: 768px) {
  body.dark .furry-text {
    border: 1px solid var(--border-color-dark); /* 移动端恢复完整边框 */
  }
  
  body.dark .furry-img img {
    border: 1px solid var(--border-color-dark);
  }
}