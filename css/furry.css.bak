/* 自定义 CSS for Fluid 主题 */

/* 容器样式 */
.furry-container {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  gap: 20px;
  margin: 40px auto;
  padding: 24px;
  border-radius: 24px;
  max-width: 1200px;
  background: linear-gradient(135deg, #f5e0a6, #fff5d1, #f0f8ff);
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1), 0 2px 4px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

/* 悬停效果 */
.furry-container:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15), 0 4px 8px rgba(0, 0, 0, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.6);
}

/* 文字区域样式 */
.furry-text {
  flex: 1;
  min-width: 250px;
  color: #2c3e50;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(6px);
  border-radius: 12px;
  padding: 16px;
  border: 1px solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  line-height: 1.6;
  font-size: 16px;
}

/* 图片区域样式 */
.furry-img {
  flex: 0 0 auto; /* 自适应宽度 */
  max-width: 100%;
  min-height: 200px;
}

.furry-img img {
  width: 100%;
  max-width: 100%; /* 确保图片不超过容器 */
  height: auto;
  border-radius: 16px;
  padding: 0; /* 移除内边距，避免宽度溢出 */
