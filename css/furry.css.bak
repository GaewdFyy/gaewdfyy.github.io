/* 自定义 CSS for Fluid 主题 */

/* 容器样式 */
.furry-container {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  gap: 20px;
  margin: 40px auto;
  padding: 24px;
  border-radius: 24px;
  max-width: 1200px;
  background: linear-gradient(135deg, #f5e0a6, #fff5d1, #f0f8ff);
  box-shadow: 0 6px 16px rgba(0, 0, 0, 0.1), 0 2px 4px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

/* 悬停效果 */
.furry-container:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15), 0 4px 8px rgba(0, 0, 0, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.6);
}

/* 文字区域样式 */
.furry-text {
  flex: 1;
  min-width: 250px;
  color: #2c3e50;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(6px);
  border-radius: 12px;
  padding: 16px;
  border: 1px solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  line-height: 1.6;
  font-size: 16px;
}

/* 图片区域样式 */
.furry-img {
  flex: 0 0 auto; /* 自适应宽度 */
  max-width: 300px; /* 限制最大宽度，避免过宽 */
  min-height: 200px;
  margin-right: 20px; /* 增加右边距，确保与容器边框有间隙 */
}

.furry-img img {
  width: 100%;
  max-width: 100%; /* 确保图片不超过容器 */
  height: auto;
  border-radius: 16px;
  background: linear-gradient(to bottom right, rgba(255, 255, 255, 0.95), rgba(240, 248, 255, 0.8), rgba(220, 240, 255, 0.3));
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.1), 0 2px 4px rgba(0, 0, 0, 0.06);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.furry-img img:hover {
  transform: scale(1.02);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15), 0 4px 8px rgba(0, 0, 0, 0.1);
}

/* 响应式设计 */
@media (max-width: 768px) {
  .furry-container {
    flex-direction: column;
    margin: 20px 10px;
    padding: 16px;
    gap: 15px;
  }
  
  .furry-img {
    flex: 1 1 100%;
    max-width: 100%; /* 移动端图片宽度占满 */
    min-height: 180px;
    margin-right: 0; /* 移动端移除右边距 */
  }
  
  .furry-text {
    min-width: 100%;
    padding: 12px;
    font-size: 14px;
  }
}

@media (max-width: 480px) {
  .furry-container {
    margin: 10px 5px;
    padding: 12px;
    border-radius: 16px;
  }
  
  .furry-text {
    padding: 10px;
    border-radius: 8px;
  }
  
  .furry-img img {
    border-radius: 12px;
  }
}

/* 深色模式适配 */
@media (prefers-color-scheme: dark) {
  .furry-container {
    background: linear-gradient(135deg, #2c3e50, #34495e, #3a4a5c);
    border-color: rgba(255, 255, 255, 0.2);
  }
  
  .furry-text {
    background: rgba(255, 255, 255, 0.1);
    color: #ecf0f1;
    border-color: rgba(255, 255, 255, 0.2);
  }
  
  .furry-text h1,
  .furry-text h2,
  .furry-text h3 {
    color: #ffffff;
  }
  
  .furry-text p {
    color: #bdc3c7;
  }
  
  .furry-img img {
    background: linear-gradient(to bottom right, rgba(44, 62, 80, 0.95), rgba(52, 73, 94, 0.8));
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.3), 0 2px 4px rgba(0, 0, 0, 0.2);
  }
}